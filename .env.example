# =========================================================
# Telegram AI Bot — .env mẫu
# Copy file này thành `.env` rồi điền giá trị thật.
# KHÔNG commit .env thật lên git.
# =========================================================

# ---- Telegram ----
# Lấy token từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ---- Chat AI (OpenAI hoặc Deepseek) ----
OPENAI_API_KEY=sk-your-openai-or-deepseek-key
# Bỏ comment nếu dùng Deepseek:
# OPENAI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# ---- RAG embedding (khuyến nghị dùng OpenAI, vì Deepseek không có embedding) ----
OPENAI_EMBEDDING_API_KEY=sk-your-openai-embedding-key
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# SUPABASE_RAG_BUCKET=documents
# SUPABASE_RAG_TABLE=rag_chunks
# SUPABASE_CHAT_LOG_TABLE=telegram_chat_logs
# SUPABASE_USER_TABLE=user
# SUPABASE_MEMBERS_TABLE=members

# ---- RAG tuning ----
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=100
# RAG_TOP_K=8
# RAG_EMBEDDING_BATCH=50

# ---- Rate limit (chống spam) ----
# Số tin/phút tối đa mỗi chat_id gửi vào bot
# RATE_LIMIT_PER_MINUTE=20
# RATE_LIMIT_BURST=5

# =========================================================
# ĐĂNG KÝ /dk — BẮT BUỘC khi muốn duyệt user mới
# =========================================================
# Email mặc định gán vào cột `useremail` khi admin duyệt /dk.
# Nếu để trống, lệnh /dk approve sẽ từ chối và yêu cầu đặt env này.
DEFAULT_REGISTRATION_USEREMAIL=
# Refresh token mặc định cho Google Calendar của user mới (có thể để trống)
DEFAULT_REGISTRATION_GCAL_REFRESH_TOKEN=

# =========================================================
# Google Calendar (tùy chọn — chỉ khi muốn nhắc lịch)
# =========================================================
# Timezone mặc định, không đổi
GCALENDAR_TZ=Asia/Ho_Chi_Minh
# DAILY_CALENDAR_HOUR=7
# DAILY_CALENDAR_MINUTE=0

# ---- Cách 1: Google Workspace (Service Account + domain-wide delegation) ----
# Bật Calendar API; Admin Console → Bảo mật → Kiểm soát API → Ủy quyền trên
# toàn miền → thêm Client ID service account với scope
# https://www.googleapis.com/auth/calendar.readonly
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ---- Cách 2: Gmail cá nhân (OAuth) ----
# Cloud Console → OAuth client (Web) → Authorized redirect URIs
# phải khớp GOOGLE_OAUTH_REDIRECT_URI.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8085/
# GOOGLE_OAUTH_CLIENT_KIND=installed   # đặt nếu bạn dùng OAuth client Desktop

# ---- Cách 3: Lịch công ty gom về 1 Gmail (master aggregator) ----
# Lịch đọc từ GCAL_MASTER_EMAIL, lọc sự kiện theo email_congty mỗi user.
# Lấy refresh token bằng: python get_gcal_refresh_token.py
# GCAL_MASTER_EMAIL=
# GCAL_MASTER_REFRESH_TOKEN=

# ---- Ẩn email trong chi tiết cuộc họp (nhiều email cách bằng dấu phẩy) ----
# MEETING_HIDE_EMAILS=
