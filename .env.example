# Telegram Bot - lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ---- Chat AI (có thể dùng Deepseek) ----
OPENAI_API_KEY=sk-your-openai-or-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# ---- RAG: Embedding riêng (chỉ cho tài liệu) ----
# RAG dùng embedding để tìm tài liệu chính xác hơn. Chat vẫn dùng OPENAI_API_KEY ở trên.
#
# Cách lấy API key OpenAI CHỈ cho embedding:
# 1. Vào https://platform.openai.com/api-keys
# 2. Đăng nhập (hoặc tạo tài khoản OpenAI)
# 3. Bấm "Create new secret key", đặt tên ví dụ "RAG Embedding"
# 4. Copy key (dạng sk-...) và dán vào OPENAI_EMBEDDING_API_KEY bên dưới
# 5. Giới hạn chi phí (tùy chọn): Vào Billing -> Limits, đặt usage limit cho key hoặc cho account
#
# Lưu ý: Có thể dùng chung key với chat (OPENAI_API_KEY) nếu bạn dùng OpenAI cho cả hai;
# nếu chat dùng Deepseek thì nên dùng key OpenAI riêng cho embedding.
#
OPENAI_EMBEDDING_API_KEY=sk-your-openai-embedding-key
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Supabase (CSDL + Storage + RAG) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# Lịch Google: thêm dòng bảng user với telegram_ID = Chat ID (lệnh /id), useremail, gcal_refresh_token (OAuth) hoặc chỉ email nếu dùng Service Account.
# SUPABASE_RAG_BUCKET=documents
# RAG_CHUNK_SIZE=800
# RAG_TOP_K=8

# ---- Google Calendar (nhắc lịch hàng ngày — tùy chọn) ----
# Cách 1 — Google Workspace: Service Account JSON + ủy quyền domain (Admin Console).
#   Bật Calendar API; Admin → Bảo mật → Kiểm soát API → Ủy quyền trên toàn miền → thêm Client ID service account,
#   scope: https://www.googleapis.com/auth/calendar.readonly
#   Trên Supabase: useremail = email Workspace (không cần gcal_refresh_token).
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
#
# Cách 2 — Gmail (@gmail.com): OAuth client Web application trong Google Cloud + refresh token trong DB.
#   Trên Supabase: điền gcal_refresh_token (lấy bằng: python get_gcal_refresh_token.py).
#   Cloud Console → OAuth client (Web) → Authorized redirect URIs: thêm ĐÚNG URI với biến dưới (mặc định http://127.0.0.1:8085/)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8085/
#
# Chế độ lịch tập trung (một Gmail chứa toàn bộ lịch, bot lọc theo email_congty):
#   python get_gcal_refresh_token.py — đăng nhập ĐÚNG tài khoản Gmail đó, rồi:
# GCAL_MASTER_EMAIL=tungtrantmct@gmail.com
# GCAL_MASTER_REFRESH_TOKEN=   # refresh token từ script (không commit lên git)
# (tuỳ chọn) GOOGLE_OAUTH_CLIENT_KIND=installed  — nếu bạn vẫn dùng OAuth client kiểu Desktop/Installed
# GCALENDAR_TZ=Asia/Ho_Chi_Minh
# DAILY_CALENDAR_HOUR=7
# DAILY_CALENDAR_MINUTE=0
